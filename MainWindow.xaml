<Window x:Class="StudentManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StudentManager"
        mc:Ignorable="d"
        Title="Student Manager"
        Height="650"
        Width="600"
        Background="white"
        WindowStartupLocation="centerScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                BorderBrush="skyblue"
                BorderThickness="2"
                CornerRadius="6"
                Background="lightblue"
                Padding="10"
                Margin="10"
                Height="90">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                    <TextBlock Text="Student Manager"
                               Foreground="black"
                               FontSize="20"
                               FontWeight="bold"
                               TextAlignment="center"/>
                    <TextBlock Text="Student and Grade Management"
                               Foreground="gray"
                               FontSize="12"
                               TextAlignment="center"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="center"
                    VerticalAlignment="top"
                    Margin="10"
                    Width="550">

            <Border CornerRadius="6"
                    Background="limegreen"
                    BorderBrush="green"
                    BorderThickness="2"
                    Padding="5"
                    Margin="10"
                    Height="60">
                <Button Name="btnOpenManagement"
                        Content="👥 Open Management"
                        Background="transparent"
                        BorderThickness="0"
                        Foreground="white"
                        FontSize="15"/>
            </Border>

            <Border BorderBrush="orange"
                    BorderThickness="2"
                    CornerRadius="6"
                    Padding="10"
                    Margin="10"
                    Background="wheat">
                <StackPanel>
                    <TextBlock Text="File Operations"
                               FontWeight="bold"
                               FontSize="18"
                               Foreground="darkorange"
                               TextAlignment="center"
                               Margin="0 0 0 10"/>

                    <TextBlock Text="TXT Format (plain text):"
                               FontWeight="bold"
                               Foreground="darkorange"
                               Margin="0 0 0 5"/>
                    <StackPanel Orientation="horizontal"
                                HorizontalAlignment="center"
                                Margin="0 0 0 10">
                        <Button Name="btnSaveToTxt"
                                Content="💾 Save TXT"
                                Width="120"
                                Height="40"
                                Background="tomato"
                                Foreground="white"
                                Margin="5"/>
                        <Button Name="btnLoadFromTxt"
                                Content="📂 Load TXT"
                                Width="120"
                                Height="40"
                                Background="orange"
                                Foreground="white"
                                Margin="5"/>
                    </StackPanel>

                    <TextBlock Text="JSON Format (serialization with grades):"
                               FontWeight="bold"
                               Foreground="purple"
                               Margin="0 0 0 5"/>
                    <StackPanel Orientation="horizontal"
                                HorizontalAlignment="center">
                        <Button Name="btnSaveToJson"
                                Content="💾 Save JSON"
                                Width="120"
                                Height="40"
                                Background="mediumorchid"
                                Foreground="white"
                                Margin="5"/>
                        <Button Name="btnLoadFromJson"
                                Content="📂 Load JSON"
                                Width="120"
                                Height="40"
                                Background="thistle"
                                Foreground="white"
                                Margin="5"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border BorderBrush="lightgreen"
                    BorderThickness="2"
                    CornerRadius="5"
                    Padding="10"
                    Margin="10"
                    Background="honeydew">
                <StackPanel>
                    <TextBlock Text="📊 Statistics"
                               FontWeight="bold"
                               FontSize="18"
                               Foreground="green"
                               TextAlignment="center"
                               Margin="0 0 0 10"/>

                    <StackPanel Orientation="horizontal"
                                HorizontalAlignment="center"
                                Margin="0 2">
                        <TextBlock Name="lblStudentsInMemory"
                                   Text="👥 Students in memory: 0"
                                   FontSize="13"
                                   Foreground="green"
                                   Margin="10,0"/>
                        <TextBlock Name="lblStudentsWithGrades"
                                   Text="📝 With grades: 0"
                                   FontSize="13"
                                   Foreground="green"
                                   Margin="10,0"/>
                    </StackPanel>

                    <StackPanel Orientation="horizontal"
                                HorizontalAlignment="center"
                                Margin="0 2">
                        <TextBlock Name="lblLastSave"
                                   Text="💾 Last save: none"
                                   FontSize="13"
                                   Foreground="green"
                                   Margin="10,0"/>
                        <TextBlock Name="lblLastLoad"
                                   Text="📂 Last load: none"
                                   FontSize="13"
                                   Foreground="green"
                                   Margin="10,0"/>
                    </StackPanel>

                    <StackPanel Orientation="horizontal"
                                HorizontalAlignment="center"
                                Margin="0 2">
                        <TextBlock Name="lblAverageGrade"
                                   Text="⭐ Average grade: 0.0"
                                   FontSize="13"
                                   Foreground="green"
                                   Margin="10,0"/>
                        <TextBlock Name="lblTopStudent"
                                   Text="🏆 Top student: none"
                                   FontSize="13"
                                   Foreground="green"
                                   Margin="10,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <StatusBar Grid.Row="2"
                   Background="LightGray"
                   Height="30">
            <StatusBarItem>
                <TextBlock Name="lblStatus"
                           Foreground="gray"
                           FontWeight="bold"
                           Text="Status: ready | DataService: ok | students: 0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>