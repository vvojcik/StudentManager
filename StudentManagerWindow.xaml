<Window x:Class="StudentManager.StudentManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Student Management"
        Height="760" Width="1050"
        Background="white"
        WindowStartupLocation="centerScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="230"/>
                <RowDefinition Height="230"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Grid.Column="0"
                    BorderBrush="lightgreen"
                    BorderThickness="2"
                    CornerRadius="8"
                    Background="mintcream"
                    Padding="10"
                    Margin="5">
                <StackPanel>
                    <TextBlock Text="Student Form"
                               FontWeight="bold"
                               FontSize="15"
                               Foreground="green"
                               HorizontalAlignment="center"/>

                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="First Name:" Grid.Row="0" Grid.Column="0" Margin="3"/>
                        <TextBox x:Name="txtFirstName" Grid.Row="0" Grid.Column="1" Margin="3"/>

                        <TextBlock Text="Last Name:" Grid.Row="0" Grid.Column="2" Margin="3"/>
                        <TextBox x:Name="txtLastName" Grid.Row="0" Grid.Column="3" Margin="3"/>

                        <TextBlock Text="Birth Date:" Grid.Row="1" Grid.Column="0" Margin="3"/>
                        <DatePicker x:Name="dpBirth" Grid.Row="1" Grid.Column="1" Margin="3"
                                    SelectedDateChanged="DpBirth_SelectedDateChanged"/>
                        <TextBlock Text="Class:" Grid.Row="1" Grid.Column="2" Margin="3"/>
                        <TextBox x:Name="txtClass" Grid.Row="1" Grid.Column="3" Margin="3"/>

                        <TextBlock Text="Age:" Grid.Row="2" Grid.Column="0" Margin="3"/>
                        <TextBlock x:Name="lblAge"
                                   Grid.Row="2" Grid.Column="1"
                                   Margin="3"
                                   Foreground="red"
                                   FontWeight="bold"/>
                    </Grid>

                    <StackPanel Orientation="horizontal" HorizontalAlignment="center">
                        <Button x:Name="btnAddStudent" Content="Add"
                                Background="limegreen" Foreground="white"
                                Width="100" Height="30" Margin="5"/>
                        <Button x:Name="btnEditStudent" Content="Edit"
                                Background="orange" Foreground="white"
                                Width="100" Height="30" Margin="5"/>
                        <Button x:Name="btnClearStudent" Content="Clear"
                                Background="skyblue" Foreground="white"
                                Width="100" Height="30" Margin="5"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="0" Grid.Column="1"
                    BorderBrush="orange"
                    BorderThickness="2"
                    CornerRadius="8"
                    Background="beige"
                    Padding="10"
                    Margin="5">
                <StackPanel>
                    <TextBlock Text="Students List"
                               FontWeight="bold"
                               FontSize="15"
                               Foreground="darkorange"
                               HorizontalAlignment="center"/>
                    <ListBox x:Name="lstStudents"
                             Height="130"
                             SelectionChanged="LstStudents_SelectionChanged"/>
                    <StackPanel Orientation="horizontal" HorizontalAlignment="center">
                        <Button x:Name="btnDeleteStudent" Content="Delete"
                                Background="indianred" Foreground="white"
                                Width="90" Height="30" Margin="5"/>
                        <Button x:Name="btnBack" Content="Back"
                                Background="gray" Foreground="white"
                                Width="90" Height="30" Margin="5"
                                Click="BtnBack_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="0"
                    BorderBrush="mediumpurple"
                    BorderThickness="2"
                    CornerRadius="8"
                    Background="lavender"
                    Padding="10"
                    Margin="5">
                <StackPanel>
                    <TextBlock x:Name="lblGradesHeader" Text="Grades (...)"
                               FontWeight="bold"
                               FontSize="15"
                               Foreground="purple"
                               HorizontalAlignment="center"/>
                    <Grid Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Subject:" Grid.Column="0" Margin="5"/>
                        <TextBox x:Name="txtSubject" Grid.Column="1" Width="120" Margin="5"/>
                        <TextBlock Text="Grade:" Grid.Column="2" Margin="5"/>
                        <TextBox x:Name="txtGrade" Grid.Column="3" Width="50" Margin="5"/>
                    </Grid>
                    <StackPanel Orientation="horizontal" HorizontalAlignment="center">
                        <TextBlock Text="Date:" Margin="5"/>
                        <DatePicker x:Name="dpGradeDate" Width="130" Margin="5"/>
                    </StackPanel>
                    <TextBox x:Name="txtDescription"
                             Margin="5"
                             Height="40"
                             Text="Description (optional)"/>
                    <StackPanel Orientation="horizontal" HorizontalAlignment="center">
                        <Button x:Name="btnAddGrade" Content="Add"
                                Background="limegreen" Foreground="white"
                                Width="90" Height="30" Margin="5"
                                Click="BtnAddGrade_Click"/>
                        <Button x:Name="btnDeleteGrade" Content="Delete"
                                Background="indianred" Foreground="white"
                                Width="90" Height="30" Margin="5"
                                Click="BtnDeleteGrade_Click"/>
                        <Button x:Name="btnRefreshGrades" Content="Refresh"
                                Background="skyblue" Foreground="white"
                                Width="90" Height="30" Margin="5"
                                Click="BtnRefreshGrades_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Grid.Column="1"
                    BorderBrush="skyblue"
                    BorderThickness="2"
                    CornerRadius="8"
                    Background="aliceblue"
                    Padding="10"
                    Margin="5">
                <StackPanel>
                    <TextBlock x:Name="lblReportHeader"
                               Text="Report (...)"
                               FontWeight="bold"
                               FontSize="15"
                               Foreground="blue"
                               HorizontalAlignment="center"/>
                    <Border BorderBrush="lightblue"
                            BorderThickness="1.5"
                            CornerRadius="6"
                            Background="white"
                            Padding="6"
                            Margin="5">
                        <TextBlock x:Name="lblStats"
                                   Text="Grades: 0 | Average: 0.00"
                                   TextAlignment="center"
                                   FontSize="13"
                                   Foreground="black"
                                   TextWrapping="wrap"/>
                    </Border>
                    <Border BorderBrush="gold"
                            BorderThickness="1.5"
                            CornerRadius="6"
                            Background="lightyellow"
                            Padding="6"
                            Margin="5">
                        <TextBlock x:Name="lblComment"
                                   Text="No comment"
                                   FontWeight="bold"
                                   Foreground="darkgoldenrod"
                                   FontSize="13"
                                   TextAlignment="center"/>
                    </Border>
                    <StackPanel Orientation="horizontal" HorizontalAlignment="center">
                        <Button x:Name="btnNewComment" Content="New"
                                Background="orange" Foreground="white"
                                Width="90" Height="30" Margin="5"
                                Click="BtnNewComment_Click"/>
                        <Button x:Name="btnSaveReport" Content="Save"
                                Background="skyblue" Foreground="white"
                                Width="90" Height="30" Margin="5"
                                Click="BtnSaveReport_Click"/>
                        <Button x:Name="btnExportTxt" Content="Export"
                                Background="limegreen" Foreground="white"
                                Width="90" Height="30" Margin="5"
                                Click="BtnExportTxt_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Grid.ColumnSpan="2"
                    BorderBrush="lightgray"
                    BorderThickness="1.5"
                    CornerRadius="6"
                    Background="whitesmoke"
                    Padding="10"
                    Margin="5">
                <StackPanel>
                    <TextBlock Text="📋 Selected student's grades"
                               FontWeight="bold"
                               FontSize="14"
                               Foreground="gray"
                               Margin="0 0 0 5"/>
                    <ScrollViewer VerticalScrollBarVisibility="auto"
                                  HorizontalScrollBarVisibility="disabled"
                                  MaxHeight="280">
                        <ListBox x:Name="lstGrades"
                                 BorderThickness="1"
                                 BorderBrush="lightgray"
                                 Background="white"
                                 Margin="0 0 0 5"
                                 MinHeight="100"
                                 MaxHeight="270"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="lightgray"
                CornerRadius="3"
                Padding="6"
                Margin="0 5 0 0">
            <TextBlock x:Name="lblStatus"
                       Text="Status: no student selected | Grades: 0 | Average: 0.00 | Comment: none"
                       FontSize="12"
                       Foreground="gray"
                       TextWrapping="wrap"/>
        </Border>
    </Grid>
</Window>